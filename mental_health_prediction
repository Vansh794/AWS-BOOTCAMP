        "OUTLIER DETECTION\n"
      ],
      "metadata": {
        "id": "ML9m7qoU4vU6"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "Q1 = df['Age'].quantile(0.25)\n",
        "Q3 = df['Age'].quantile(0.75)\n",
        "\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "lower = Q1 - 1.5 * IQR\n",
        "upper = Q3 + 1.5 * IQR\n",
        "\n",
        "df = df[(df['Age'] >= lower) & (df['Age'] <= upper)]"
      ],
      "metadata": {
        "id": "Js9GT3E34yZF"
      },
      "execution_count": 12,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "DEFINE X AND Y AND TRAIN -TEST SPLIT"
